# Product Siksha Backend Configuration
# Copy this file to .env and fill in your values

# Secret key for JWT tokens (generate a random string for production)
SECRET_KEY=dev-secret-key-change-in-production

# Anthropic API key for Claude Mentor Agent
ANTHROPIC_API_KEY=

# Google Gemini API key (for embeddings and legacy feedback)
GEMINI_API_KEY=

# Database URL (PostgreSQL for production, omit for local SQLite)
DATABASE_URL=

# Vector DB URL (Cloud SQL PostgreSQL with pgvector for RAG embeddings)
VECTOR_DB_URL=
